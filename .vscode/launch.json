{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Django",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "runserver",
                "localhost:8000",
                "--noreload"
            ],
            "django": true,
            "autoStartBrowser": false,
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "Python: Celery",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "-A",
                "project.celery_app",
                "worker",
                "-l",
                "info",
                "-P",
                "solo",
                "-E"
            ]
        },
          {
            "name": "Migrate",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "migrate",
            ],
            "django": true,
            "autoStartBrowser": false,
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "MakeMigration",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "makemigrations",
            ],
            "django": true,
            "autoStartBrowser": false,
            "program": "${workspaceFolder}/manage.py"
        },
    ]
}